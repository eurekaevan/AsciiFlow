# =========================================================================
# AsciiFlow Git Ignore Configuration
# =========================================================================

# -------------------------------------------------------------------------
# 1. 输出目录及运行产生的临时产物 (Output directory & run artifacts)
# -------------------------------------------------------------------------
output/
output*/
scratch/
*.log

# -------------------------------------------------------------------------
# 2. 多媒体文件 (Multimedia files)
# -------------------------------------------------------------------------
*.mp4
*.m4v
*.avi
*.mkv
*.mov
*.wmv
*.flv
*.webm
*.mp3
*.wav
*.aac
*.flac
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.webp

# -------------------------------------------------------------------------
# 3. .NET 编译及构建非源码文件 (Build & compilation artifacts)
# -------------------------------------------------------------------------
[Bb]in/
[Oo]bj/
[Tt]emp/
[Ll]og/
*.user
*.userosscache
*.sln.docstates
*.userprefs
*.suo

# NuGet 临时文件
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets
project.lock.json
project.assets.json

# 编译产生的动态/静态库和调试符号
*.dll
*.exe
*.pdb
*.so
*.so.*
*.dylib

# -------------------------------------------------------------------------
# 4. IDE 及编辑器配置文件 (IDE & Editor files)
# -------------------------------------------------------------------------
.vs/
.idea/
.vscode/
*.swp
*~
.DS_Store
Thumbs.db

# -------------------------------------------------------------------------
# 5. FFmpeg 本地二进制动态库目录 (FFmpeg binary libraries)
# -------------------------------------------------------------------------
ffmpeg/windows/
ffmpeg/linux/
ffmpeg/macos/
